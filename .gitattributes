# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly LF for code and config
*.sh      text eol=lf
*.bash    text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
*.toml    text eol=lf
*.env     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf

# Binary — never convert
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
